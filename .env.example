# GPE-Practice environment template
#
# Copy this file to `.env` (gitignored) and fill in real values.
# Used by:
#   - tools/llm-emit-generator.ts  (Phase 6 — register-new-question workflow)
#   - GitHub Actions secrets (same names; configure under repo Settings)
#
# The LLM client is intentionally provider-agnostic. We use the `openai` npm
# package (or fetch directly), and most providers ship an OpenAI-compatible
# chat-completions endpoint. Override LLM_BASE_URL + LLM_MODEL to swap.

# ---------------------------------------------------------------------------
# Option A — Google Gemini (OpenAI-compatible endpoint)
# ---------------------------------------------------------------------------
# Get a key from https://aistudio.google.com/apikey
# Pricing & quotas: https://ai.google.dev/pricing
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_API_KEY=AIza-...your-key-here...
LLM_MODEL=gemini-3.1-flash-lite

# ---------------------------------------------------------------------------
# Option B — Anthropic Claude (uncomment + comment-out Option A to use)
# ---------------------------------------------------------------------------
# Get a key from https://console.anthropic.com/settings/keys
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_API_KEY=sk-ant-...your-key-here...
# LLM_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Option C — OpenAI (uncomment + comment-out Option A to use)
# ---------------------------------------------------------------------------
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...your-key-here...
# LLM_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Option D — Local Ollama (no network; great for offline dev)
# ---------------------------------------------------------------------------
# Requires `ollama serve` running locally with a model pulled.
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1:8b
