    "comlink": "^4.4.2",
    "highlight.js": "^11.11.1",
    "i18next": "^23.16.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.453.0",
    "monaco-editor": "^0.52.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.0",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.27.0",
    "rehype-highlight": "^7.0.2",
    "tailwind-merge": "^2.6.1",
